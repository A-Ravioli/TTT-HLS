# Prime Intellect Inference API (OpenAI-compatible). Enables GLM 5.2 without local GPU weights.
PRIME_API_KEY=your_prime_api_key
# PRIME_TEAM_ID=your_team_id

# GLM backend: prime (API) | hf (local HuggingFace weights) | heuristic (offline stand-in)
BURN_GLM_BACKEND=prime
# Prime Inference GLM models: z-ai/glm-5.2, z-ai/glm-5.1, z-ai/glm-5, z-ai/glm-4.7-flash,
# z-ai/glm-4.7, z-ai/glm-4.6, z-ai/glm-4.5-air, z-ai/glm-4.5
BURN_GLM_MODEL=z-ai/glm-5.2
BURN_GLM_MAX_TOKENS=8192

# Local HF on Prime GPU pod (LoRA TTT). Use -hf weights (NOT glm-4-9b-chat — breaks on transformers 5.x):
# BURN_GLM_BACKEND=hf
# BURN_GLM_MODEL=THUDM/glm-4-9b-chat-hf

# Weights & Biases (optional; set WANDB_MODE=disabled to turn off)
WANDB_API_KEY=your_wandb_key
WANDB_PROJECT=burnttt
WANDB_RUN_NAME=ttt-config-smoke

# Prime pod runner (scripts/17_prime_run_ttt.sh) — see .env.pod.example
# KEEP_POD=1
