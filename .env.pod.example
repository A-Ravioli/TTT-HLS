# Persisted Prime pod connection (copy to .env.pod after create; gitignored).
PRIME_POD_ID=your_pod_id
SSH_HOST=192.0.2.1
SSH_USER=ubuntu
SSH_KEY=~/.ssh/id_ed25519

# GLM-5.2 LoRA TTT on GPU pod (744B MoE — needs 8 GPUs on Prime: 8×A100_80GB)
BURN_GLM_BACKEND=hf
BURN_GLM_MODEL_POD=zai-org/GLM-5.2-FP8
GPU_TYPE=A100_80GB
GPU_COUNT=8
BURN_GLM_MAX_SEQ_LEN=2048
BURN_TARGET_PART=xc7z020clg400-1

# Laptop / API authoring (no weight updates): z-ai/glm-5.2 via Prime Inference
# BURN_GLM_BACKEND=prime
# BURN_GLM_MODEL=z-ai/glm-5.2

WANDB_PROJECT=burnttt
WANDB_RUN_NAME=prime-glm52-ttt
ROUNDS=8
CANDIDATES=3
KEEP_POD=1
